{
  "name": "chittymarket",
  "owner": {
    "name": "ChittyOS",
    "email": "dev@chitty.cc"
  },
  "metadata": {
    "description": "ChittyOS ecosystem plugins, skills, agents, and hooks for Claude Code",
    "version": "1.0.0"
  },
  "plugins": [
    {
      "name": "chittyhelper",
      "description": "Architectural navigation — ask 'which service handles X?' queries against the ChittyOS ecosystem",
      "version": "1.0.0",
      "source": {
        "source": "github",
        "repo": "CHITTYOS/chittyhelper"
      },
      "strict": false,
      "category": "ecosystem",
      "keywords": ["chittyos", "architecture", "navigation", "services"],
      "skills": ["./skills/chittyhelper"],
      "commands": ["./commands/"],
      "agents": ["./agents/chittyhelper-navigator.md"]
    },
    {
      "name": "chittyagent",
      "description": "ChittyOS session lifecycle — authenticated bootstrap, ecosystem routing, session identity, and Mercury finance",
      "version": "0.1.0",
      "source": {
        "source": "github",
        "repo": "CHITTYOS/chittyagent"
      },
      "strict": false,
      "category": "ecosystem",
      "keywords": ["chittyos", "session", "bootstrap", "identity", "ecosystem"],
      "skills": [
        "./skills/ecosystem-router",
        "./skills/session-identity",
        "./skills/mercury-finance"
      ],
      "commands": ["./commands/"],
      "hooks": "./hooks/hooks.json"
    },
    {
      "name": "chittycommand",
      "description": "Life management dashboard — query finances, manage disputes, monitor syncs, get AI-powered recommendations",
      "version": "0.1.0",
      "source": {
        "source": "github",
        "repo": "CHITTYOS/chittycommand"
      },
      "strict": false,
      "category": "productivity",
      "keywords": ["dashboard", "finance", "disputes", "obligations", "cashflow"],
      "skills": ["./skills/chittycommand"],
      "commands": ["./commands/"],
      "agents": [
        "./agents/dispute-strategist.md",
        "./agents/recommendation-engine.md",
        "./agents/sync-monitor.md",
        "./agents/urgency-advisor.md"
      ],
      "mcpServers": "./.mcp.json"
    },
    {
      "name": "legal-arsenal",
      "description": "Legal case management — evidence standards, chain of custody, adversarial analysis with ChittyStorage integration",
      "version": "1.0.0",
      "source": {
        "source": "github",
        "repo": "CHITTYOS/legal-cases"
      },
      "strict": false,
      "category": "legal",
      "keywords": ["legal", "evidence", "cases", "disputes", "custody", "docket"]
    },
    {
      "name": "github-workflows",
      "description": "GitHub Actions, Issues, and PR management via gh CLI",
      "version": "1.0.0",
      "source": {
        "source": "github",
        "repo": "CHITTYOS/chittyagent"
      },
      "strict": false,
      "category": "code",
      "keywords": ["github", "actions", "ci", "workflows", "pr", "issues"],
      "commands": ["./commands/"]
    }
  ]
}
